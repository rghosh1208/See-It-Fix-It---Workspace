# ----- Supabase -----
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...   # server-only, do NOT expose

# ----- Qualtrics -----
QUALTRICS_API_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
QUALTRICS_SURVEY_ID=SV_xxxxxxxxxxxxxxx
QUALTRICS_DATACENTER=iad1                # e.g. iad1, syd1, fra1, sjc1

# ----- Cron protection -----
# Vercel generates a CRON_SECRET automatically when you add a cron job.
# Set it in Vercel project env vars; locally you can leave it blank to bypass.
CRON_SECRET=
